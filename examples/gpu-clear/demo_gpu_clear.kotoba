(ns demo-gpu-clear)

;; -16776961 is the signed-i32 bit pattern of packed RGBA8 0xFF0000FF
;; (opaque red) -- see kotoba-core-contracts' gpu-clear host-import for the
;; wire format. Track B Phase 0 spike (ADR-2607078000): a real, host-owned
;; WebGPU canvas cleared to this color, called from a compiled .kotoba
;; guest via a synchronous host-import.
(defn main []
  (gpu-clear -16776961))
